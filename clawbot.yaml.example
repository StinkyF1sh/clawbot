# Clawbot Configuration Example
#
# Environment Variable Override:
#   Values in this file can be overridden using environment variables with the CLAWBOT_ prefix.
#   Nested fields use double underscore (__) as delimiter.
#
#   Examples:
#     CLAWBOT_AGENTS__DEFAULT__MODEL=gpt-4
#     CLAWBOT_AGENTS__DEFAULT__TEMPERATURE=0.0
#     CLAWBOT_PROVIDERS__OPENAI__API_KEY=sk-xxx
#
#   Environment variables take priority over YAML config values.

agents:
  default:
    workspace: ~/.clawbot/workspace
    model: zhipu/glm-4.7
    max_tokens: 8192
    temperature: 0.1
    max_steps: 40
    memory_window: 100

  # Additional agent profiles
  # code:
  #   model: gpt-4
  #   temperature: 0.0
  # chat:
  #   model: zhipu/glm-4-flash
  #   temperature: 0.7

providers:
  openai:
    api_key: ""  # Or set CLAWBOT_PROVIDERS__OPENAI__API_KEY
    api_base: https://api.openai.com/v1
    extra_headers: null

  zhipu:
    api_key: ""  # Or set CLAWBOT_PROVIDERS__ZHIPU__API_KEY
    api_base: https://open.bigmodel.cn/api/paas/v4
    extra_headers: null

  bailian:
    api_key: ""  # Or set CLAWBOT_PROVIDERS__BAILIAN__API_KEY
    api_base: https://dashscope.aliyuncs.com/compatible-mode/v1
    extra_headers: null
